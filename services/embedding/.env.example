# ========================================
# Embedding Service Configuration
# ========================================
# This file contains environment variables for the embedding service.
# Copy this file to .env and adjust the values as needed.

# ========================================
# Backend Configuration
# ========================================
# Available backends: ollama, transformers
# ollama: Uses Ollama for local inference (faster, requires Ollama)
# transformers: Uses sentence-transformers (slower, more accurate)
BACKEND_TYPE=ollama

# ========================================
# Ollama Configuration (when BACKEND_TYPE=ollama)
# ========================================
# Base URL for Ollama API
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for embeddings
# Recommended: hf.co/ChristianAzinn/e5-large-v2-gguf:Q8_0 (quantized, faster)
# Alternative: intfloat/e5-large (original, slower)
OLLAMA_MODEL=hf.co/ChristianAzinn/e5-large-v2-gguf:Q8_0

# ========================================
# Model Configuration (when BACKEND_TYPE=transformers)
# ========================================
# Model name from Hugging Face
MODEL_NAME=intfloat/e5-large

# Embedding dimension (must match the model)
EMBEDDING_DIM=1024

# Batch size for processing multiple texts
BATCH_SIZE=32

# Maximum text length for embeddings
MAX_LENGTH=512

# ========================================
# Redis Configuration (optional but recommended)
# ========================================
# Redis connection URL
# Format: redis://[password@]host:port/db
REDIS_URL=redis://localhost:6379/0

# Redis password (if required)
REDIS_PASSWORD=

# Cache TTL in seconds (default: 24 hours)
CACHE_TTL=86400

# ========================================
# Server Configuration
# ========================================
# Host to bind the server to
HOST=0.0.0.0

# Port to listen on
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========================================
# Timeout Configuration
# ========================================
# Request timeout in seconds
REQUEST_TIMEOUT=30

# Connection timeout in seconds
CONNECTION_TIMEOUT=10

# ========================================
# Advanced Configuration
# ========================================
# Enable CORS (set to "false" to disable)
CORS_ENABLED=true

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=*

# Enable request rate limiting
RATE_LIMIT_ENABLED=false

# Maximum requests per minute
RATE_LIMIT_PER_MINUTE=60

# ========================================
# Monitoring & Debugging
# ========================================
# Enable detailed logging
DEBUG_MODE=false

# Enable health check endpoint (always enabled)
HEALTH_CHECK_ENABLED=true

# Enable OpenAPI documentation
DOCS_ENABLED=true

# ========================================
# Performance Tuning
# ========================================
# Number of worker processes for uvicorn
# Set to 0 to auto-detect (number of CPU cores)
WORKERS=1

# Maximum concurrent requests
MAX_CONCURRENT_REQUESTS=100

# Response compression (gzip)
COMPRESSION_ENABLED=true

# ========================================
# Security
# ========================================
# Enable API key authentication (optional)
API_KEY_ENABLED=false

# API key (required if API_KEY_ENABLED=true)
API_KEY=

# Enable request signing (optional)
SIGNING_ENABLED=false

# Secret key for request signing
SIGNING_SECRET=

# ========================================
# Feature Flags
# ========================================
# Enable text normalization (recommended)
NORMALIZATION_ENABLED=true

# Enable prefix support for e5 models
PREFIX_SUPPORT=true

# Enable async processing
ASYNC_PROCESSING=true

# Maximum queue size for async processing
ASYNC_QUEUE_SIZE=1000



#  ollama run hf.co/ChristianAzinn/e5-large-v2-gguf:Q8_0